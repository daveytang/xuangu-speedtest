# Nginx反向代理配置示例
# 将此配置放在 /etc/nginx/sites-available/xuangu-speedtest
# 然后软链接到 /etc/nginx/sites-enabled/

upstream speedtest_backend {
    server 127.0.0.1:3000;
    keepalive 64;
}

server {
    listen 80;
    listen [::]:80;
    server_name your-domain.com;  # 替换为你的域名

    # 如果已配置SSL，取消下面的注释并注释掉上面的listen 80
    # listen 443 ssl http2;
    # listen [::]:443 ssl http2;
    # ssl_certificate /path/to/cert.pem;
    # ssl_certificate_key /path/to/key.pem;

    client_max_body_size 600M;  # 上传测速最大512MB + 余量
    client_body_timeout 120s;
    send_timeout 120s;

    # 日志
    access_log /var/log/nginx/xuangu-speedtest-access.log;
    error_log /var/log/nginx/xuangu-speedtest-error.log;

    # 根路径
    location / {
        proxy_pass http://speedtest_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        # 静态资源缓存
        location ~* \.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$ {
            proxy_pass http://speedtest_backend;
            proxy_cache_valid 200 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # 测速API：关键配置
    location /api/ {
        proxy_pass http://speedtest_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        # 禁用缓存（关键！）
        proxy_cache off;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
        add_header Pragma "no-cache";

        # 禁用Gzip（关键！测速必须测原始带宽）
        gzip off;
        proxy_set_header Accept-Encoding "";

        # 禁用缓冲（关键！流式传输必须实时）
        proxy_buffering off;
        proxy_request_buffering off;

        # 超时设置（测速需要较长时间）
        proxy_connect_timeout 10s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }
}
